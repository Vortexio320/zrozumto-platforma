# --- Supabase (required) ---
# Project URL and keys from Supabase dashboard (Settings > API).
SUPABASE_URL=https://your-project.supabase.co
# Service role key — server-side only; never expose to the browser.
SUPABASE_KEY=
# Anonymous key — exposed to the frontend via /api/config for the Supabase client.
SUPABASE_ANON_KEY=

# --- Google Gemini (required for AI features) ---
GOOGLE_API_KEY=

# --- Neo4j (required for exam tasks & skill graph) ---
# Format: neo4j/<password> or just the password (see app/neo4j.py).
NEO4J_AUTH=neo4j/change-me
# Bolt URI. docker-compose overrides this for the `web` service to bolt://neo4j:7687.
# For local tools connecting to the mapped port: bolt://127.0.0.1:7688
NEO4J_URI=bolt://127.0.0.1:7688

# --- Webhooks (n8n ingest) ---
WEBHOOK_SECRET=

# --- Optional ---
# Comma-separated origins for CORS (defaults include localhost:8000).
# CORS_ORIGINS=http://localhost:5173,http://localhost:8000
# Synthetic email domain used when mapping username -> email at login.
# USER_EMAIL_DOMAIN=zrozum-to.pl
# Set true behind HTTPS in production.
# COOKIE_SECURE=false
